<div class="news">
  {% if site.news != blank %}
    {% assign news_size = site.news | size %}
    <div
      class="table-responsive"
      {% if include.limit and site.announcements.scrollable and news_size > 3 %}
        style="max-height: 60vw"
      {% endif %}
    >
      <table class="table table-sm table-borderless">
        {% assign news = site.news | reverse %}
        {% if include.limit and site.announcements.limit %}
          {% assign news_limit = site.announcements.limit %}
        {% else %}
          {% assign news_limit = news_size %}
        {% endif %}
        {% assign shown_news = 0 %}
        {% for item in news %}
          {% if include.limit and site.announcements.limit and shown_news >= site.announcements.limit %}
            {% break %}
          {% endif %}
          <tr>
            <th scope="row" class="news-date">
              <span class="news-date-month">{{ item.date | date: '%b' }}</span>
              <span class="news-date-year">{{ item.date | date: '%Y' }}</span>
            </th>
            <td>
              {% if item.inline %}
                {{ item.content | remove: '<p>' | remove: '</p>' | emojify }}
              {% else %}
                <a class="news-title" href="{{ item.url | relative_url }}">{{ item.title }}</a>
              {% endif %}
            </td>
          </tr>
          {% assign shown_news = shown_news | plus: 1 %}
        {% endfor %}
      </table>
    </div>
  {% else %}
    <p>No news so far...</p>
  {% endif %}
</div>

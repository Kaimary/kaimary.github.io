---
layout: default
---
<div class="post">
  <header class="post-header{% if page.profile.align == 'left' %} profile-left{% endif %}">
    <h1 class="post-title">
      {% if site.title == 'blank' %}
        <span class="font-weight-bold">{{ site.first_name }}</span> {{ site.middle_name }}
        {{ site.last_name }}
      {% else %}
        {{ site.title }}
      {% endif %}
    </h1>
    {% if page.subtitle %}
      <p class="desc">{{ page.subtitle }}</p>
    {% endif %}
  </header>

        <article>
          {% if page.profile -%}
          <div class="profile float-{%- if page.profile.align == 'left' -%}left{%- else -%}right{%- endif -%}">
            {%- if page.profile.logo %}
              {%- assign profile_logo_path = page.profile.logo | prepend: 'assets/img/' -%}
              {% include figure.liquid 
              path=profile_logo_path 
              class="img-fluid z-dept-1 rounded"
              alt=page.profile.logo
              title="Department of Computer Science"
              -%}
            {% endif -%}
            {%- if page.profile.image %}
              {%- assign profile_image_path = page.profile.image | prepend: 'assets/img/' -%}
              {% include figure.liquid 
              path=profile_image_path 
              class="profile"
              alt=page.profile.image
              title="You enlightened me!"
              -%}
            {% endif -%}
            {%- if page.profile.address %}
            <div class="address">
              {{ page.profile.address }}
            </div>
            {%- endif %}
          </div>
          {%- endif %}

    <div class="clearfix about-content">{{ content }}</div>

    <!-- Openings -->
    {% if page.openings %}
      <h2 class="openings-heading">Openings</h2>
      <p class="openings-text">
        Seeking highly motivated students who can intern in Shanghai for 3+ months. If you’re passionate about AI systems, please email me your CV. Experience with deep learning training/inference frameworks (deepspeed/megatron-lm/sglang/vllm), distributed caching systems (mooncake/dynamo), or distributed computing frameworks (ray) is a plus but not required.
      </p>
    {% endif %}

    <!-- News -->
    {% if page.news and site.announcements.enabled %}
      <h2 class="news-heading">
        <a href="{{ '/news/' | relative_url }}" style="color: inherit">News</a>
      </h2>
      {% include news.liquid limit=true %}
    {% endif %}

    <!-- Latest posts -->
    {% if site.latest_posts.enabled %}
      <h2>
        <a href="{{ '/blog/' | relative_url }}" style="color: inherit">latest posts</a>
      </h2>
      {% include latest_posts.liquid %}
    {% endif %}

    <!-- Under review -->
    {% if page.under_review_section or page.under_review_papers %}
      <h2 class="under-review-heading">Working Papers</h2>
      {% include under_review.liquid %}
    {% endif %}

    <!-- Selected papers -->
    {% if page.selected_papers %}
      <h2 class="selected-publications-heading">
        <a href="{{ '/publications/' | relative_url }}" style="color: inherit">Selected Publications</a>
      </h2>
      {% include selected_papers.liquid %}
    {% endif %}

    {% if site.homepage_last_update %}
      <p class="homepage-last-update">Last Update: {{ site.homepage_last_update }}</p>
    {% endif %}

    <!-- Social -->
    {% if page.social %}
      <div class="social">
        <div class="contact-icons">{% include social.liquid %}</div>

        <div class="contact-note">{{ site.contact_note }}</div>
      </div>
    {% endif %}
  </article>
</div>
